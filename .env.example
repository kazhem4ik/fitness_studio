# Токен вашего Telegram бота (получить у @BotFather)
TG_BOT_TOKEN=ваштелеграмтокенздесь

# Токен для интеграции с MAX (опционально для локальной разработки)
MAX_BOT_TOKEN=ваш_макс_токен_здесь

# Базовый URL вашего сервера для вебхуков (например, https://ваша-ссылка.ngrok.io или домен)
# Не обязателен, если вы используете только long-polling
WEBHOOK_HOST=https://example.com

# ID администратора для уведомлений (можно узнать через @userinfobot)
ADMIN_CHAT_ID=
